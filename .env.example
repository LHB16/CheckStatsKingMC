# ==================================================
# BOT SYSTEM CONFIGURATION
# ==================================================

# 1. Chế độ hoạt động (BOT_ROLE):
# - 'master': Chạy trên Render Main (Chỉ chạy Discord Bot & Điều phối Queue)
# - 'worker': Chạy trên các Render Vệ tinh (Chỉ chạy 1 Minecraft Bot AFK + API Server trên IP riêng)
# - 'standalone': (Mặc định) Chạy cả Discord Bot lẫn 1 Minecraft Bot local trên 1 Render duy nhất
BOT_ROLE=standalone

# Secret key để bảo mật kết nối API giữa Master và các Worker (Nếu dùng nhiều Render)
WORKER_SECRET=my_super_secret_key_123

# Danh sách URL Render Workers (Phân cách bởi dấu phẩy, dùng cho Master)
# VÍ DỤ: WORKER_URLS=https://kingmc-worker1.onrender.com,https://kingmc-worker2.onrender.com
WORKER_URLS=

# ==================================================
# DISCORD BOT CONFIG (Cần cho Master và Standalone)
# ==================================================
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_client_id_here
GUILD_ID=your_discord_test_guild_id_here

# Discord Admin ID để nhận tin nhắn báo lỗi
ADMIN_ID=your_discord_user_id_here

# ==================================================
# MINECRAFT BOT CONFIG (Cần cho Worker và Standalone)
# ==================================================
MC_USERNAME=CheckStatsBot01
MC_AUTH_TYPE=offline
MC_PASSWORD=your_password_here

# Server Fallback List (comma-separated, in order of priority)
MC_SERVER_HOSTS=sgp.kingmc.vn,kingmc.vn
MC_SERVER_PORT=25565

# Rate limit & Timeout configs (ms)
BOT_CHECK_TIMEOUT=15000
